<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Chiko.WirelessControl.App.Views.Controls.MetricCard"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        Background="{Binding CardBackground, Source={x:Reference Root}}"
        Stroke="{StaticResource Border}"
        StrokeThickness="1"
        StrokeShape="{StaticResource RR18}"
        Padding="14">

        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,Auto">
            <Label
                Grid.Row="0" Grid.ColumnSpan="2"
                Text="{Binding Title, Source={x:Reference Root}}"
                TextColor="{StaticResource TextSecondary}"
                FontSize="13"
                FontAttributes="Bold"/>

            <Label
                Grid.Row="1" Grid.ColumnSpan="2"
                Text="{Binding ValueText, Source={x:Reference Root}}"
                Style="{StaticResource ValueBigStyle}"
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center"
                MaxLines="1"
                LineBreakMode="TailTruncation"/>

            <Label
                Grid.Row="2" Grid.Column="1"
                Text="{Binding Unit, Source={x:Reference Root}}"
                TextColor="{StaticResource TextSecondary}"
                FontSize="13"
                HorizontalTextAlignment="End"/>
        </Grid>
    </Border>
</ContentView>
